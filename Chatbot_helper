import os
from dotenv import load_dotenv
from langchain.prompts import PromptTemplate
from langchain_google_genai import GoogleGenerativeAI
from langchain.chains import LLMChain

load_dotenv()  # Load your GOOGLE_API_KEY from .env

def generate_response(environment, threat_type):
    llm = GoogleGenerativeAI(
        model="gemini-1.5-flash",
        google_api_key=os.getenv("GOOGLE_API_KEY"),
        temperature=0.6
    )

    prompt_template = PromptTemplate(
        input_variables=["environment", "threat_type"],
        template="Suggest 5 immediate security response steps and recommended surveillance measures suitable for a {environment} environment when a {threat_type} is detected."
    )

    chain = LLMChain(llm=llm, prompt=prompt_template)
    response = chain.run({'environment': environment, 'threat_type': threat_type})
    return response
